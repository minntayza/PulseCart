# PulseCart Backend - Environment Variables
# Copy this file to .env and fill in your values

# Demo mode: uses hardcoded tokens and mock data (no Supabase required)
USE_MOCK_DATA=true

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Supabase (required when USE_MOCK_DATA=false)
SUPABASE_URL=your_supabase_url
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SECRET_KEY=your_secret_key

# LLM API Keys (for agent workflows)
ANTHROPIC_API_KEY=your_anthropic_api_key
APP_ENV=development
USE_MOCK_DATA=true
FRONTEND_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Gmail SMTP: enable only after filling all private values in backend/.env.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=your-16-digit-google-app-password
SMTP_FROM_EMAIL=your-account@gmail.com
SMTP_USE_TLS=true
