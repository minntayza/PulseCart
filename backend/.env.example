APP_ENV=development
USE_MOCK_DATA=true
FRONTEND_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Gmail SMTP: enable only after filling all private values in backend/.env.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=your-16-digit-google-app-password
SMTP_FROM_EMAIL=your-account@gmail.com
SMTP_USE_TLS=true
